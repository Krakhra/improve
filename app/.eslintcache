ort Navbar from './navbar/Navbar';\nimport Pricing from './pricing/Pricing';\n\nconst App = ()=>(\n  <div className=\"App\">\n    <Navbar/>\n    <Router>\n      <Switch>\n        <Route path=\"/\" exact component = {Home}/>\n        <Route path=\"/pricing\" exact component = {Pricing}/>\n      </Switch>\n    </Router>\n  </div>\n);\n\n\nexport default App;\n","/Users/kiratrakhra/Desktop/improve/improve/app/src/reportWebVitals.js",[],"/Users/kiratrakhra/Desktop/improve/improve/app/src/home/Home.js",["32"],"import React from 'react';\nimport './Home.css';\nimport graph from './graph.png'\n\nconst Home = () =>(\n  <div className =\"home\">\n    <div className =\"about\">\n      <p className=\"aboutDescription\">\n        Become a better version of yourself with Improve\n      </p>\n      <p style={{color:'white',fontSize:'25px',paddingLeft:'60px'}}>\n        Using advanced mood tracking algorithms, discover the patterns in your life and how to Improve.\n      </p>\n    </div>\n    <div style={{textAlign:'center'}}className =\"content\">\n      <p style={{color:'#fe5f55',fontSize:'75px'}}>\n        Some of our Features\n      </p>\n      <div className = \"container\">\n        <div className =\"row\">\n          <div style={{boxShadow:'5px 10px 8px #888888',height:'400px'}} className=\"col-lg-4\">\n            <p style={{color:'#1a012b',fontSize:'20px',marginBottom:'50px'}}>Journaling</p>\n            <form>\n              <div className=\"form-group\">\n                <label for=\"exampleInputEmail1\">Journal Title</label>\n                <input type=\"email\" class=\"form-control\" id=\"exampleInputEmail1\" aria-describedby=\"emailHelp\" placeholder=\"Enter Title\"/>\n              </div>\n              <div class=\"form-group\">\n                <label for=\"exampleFormControlTextarea1\">Journal</label>\n                <textarea class=\"form-control\" id=\"exampleFormControlTextarea1\" rows=\"3\"></textarea>\n              </div>\n              <button style={{marginTop:'15px',float:'left', backgroundColor:'#1a012b',border:'none'}} type=\"submit\" class=\"btn btn-primary\">Submit</button>\n            </form>\n          </div>\n          <div  style={{boxShadow:'5px 10px 8px #888888',height:'400px'}} className=\"col-lg-4\">\n            <p style={{color:'#1a012b',fontSize:'20px'}}>Advanced Analytics</p>\n            <img src={graph}/>\n          </div>\n          <div style={{boxShadow:'5px 10px 8px #888888',height:'400px'}} className=\"col-lg-4\">\n            <p style={{color:'#1a012b',fontSize:'20px'}}>Mood Improvement</p>\n            <i style={{fontSize:'200px',marginTop:'30px',color:'#fe5f55'}}class=\"fas fa-smile\"></i>\n          </div>\n        </div>\n      </div>\n    </div>\n\n  </div>\n);\n\nexport default Home;","/Users/kiratrakhra/Desktop/improve/improve/app/src/navbar/Navbar.js",[],"/Users/kiratrakhra/Desktop/improve/improve/app/src/pricing/Pricing.js",[],{"ruleId":"33","replacedBy":"34"},{"ruleId":"35","replacedBy":"36"},{"ruleId":"37","severity":1,"message":"38","line":3,"column":47,"nodeType":"39","messageId":"40","endLine":3,"endColumn":55},{"ruleId":"41","severity":1,"message":"42","line":37,"column":13,"nodeType":"43","endLine":37,"endColumn":31},"no-native-reassign",["44"],"no-negated-in-lhs",["45"],"no-unused-vars","'Redirect' is defined but never used.","Identifier","unusedVar","jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","JSXOpeningElement","no-global-assign","no-unsafe-negation"]